# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# CloudFuze Backend (agent calls BASE_URL + /api/user/count, /api/user/..., etc.)
# If you get 404, confirm the correct base URL with CloudFuze (e.g. with or without /cfcommon).
CLOUDFUZE_BASE_URL=http://localhost:8080
CLOUDFUZE_TOKEN=your-cloudfuze-bearer-token

# Redis (optional — gracefully degrades if unavailable)
REDIS_URL=redis://localhost:6379/0

# Application
AGENT_PORT=8082
DEBUG=false
LOG_LEVEL=INFO
API_REQUEST_TIMEOUT=30
API_MAX_RETRIES=3
